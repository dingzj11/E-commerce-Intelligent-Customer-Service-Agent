# ==================== 应用环境 ====================
APP_ENV=development
# APP_ENV=production
DEBUG=true
# 实例ID（K8s 环境下自动获取 pod name）
# INSTANCE_ID=rasa-ecs-pod-0

# ==================== LLM API ====================
API_KEY=your_api_key_here
LLM_API_HEALTH_CHECK=true
RASA_PRO_BETA_FINE_TUNING_RECIPE=true

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TRACKER_DB=1
REDIS_LOCK_DB=2
REDIS_EVENT_BROKER_DB=3
REDIS_KEY_PREFIX=rasa_ecs:
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_CONNECT_TIMEOUT=5
# REDIS_SSL=false
# REDIS_MODE=standalone
# REDIS_SENTINEL_MASTER=mymaster
# REDIS_SENTINEL_HOSTS=host1:26379,host2:26379

# ==================== MySQL 配置 ====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=ecs
MYSQL_POOL_SIZE=20
MYSQL_MAX_OVERFLOW=40
MYSQL_POOL_RECYCLE=3600
# MYSQL_READ_HOST=mysql-read-replica.local  # 读写分离（可选）

# ==================== Neo4j 配置 ====================
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_POOL_SIZE=50

# ==================== 缓存 TTL 配置（秒） ====================
CACHE_TTL_REGIONS=86400
CACHE_TTL_LOGISTICS=86400
CACHE_TTL_CATEGORY=3600
CACHE_TTL_ORDER=300
CACHE_TTL_REASONS=3600
CACHE_TTL_EMBEDDING=86400

# ==================== 限流配置 ====================
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_USER=10
RATE_LIMIT_IP=30
RATE_LIMIT_POSTSALE=5

# ==================== 分布式锁配置 ====================
LOCK_MAX_RETRY=3
LOCK_TIMEOUT=10
